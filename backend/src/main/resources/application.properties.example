# Copy this file, rename to application.properties and fill in your values

# Server
server.port=8080

# PostgreSQL
spring.datasource.url=jdbc:postgresql://localhost:5432/expense_db
spring.datasource.username=your_db_username
spring.datasource.password=your_db_password
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# JWT
jwt.secret=your_jwt_secret_min_32_chars
jwt.expiration=86400000

# Ollama (optional)
ollama.base-url=http://localhost:11434
ollama.model=mistral

# HuggingFace (optional)
huggingface.api-key=
huggingface.model=mistralai/Mistral-7B-Instruct-v0.1
huggingface.enabled=false

# Groq (FREE - get key at https://console.groq.com)
groq.api-key=your_groq_api_key_here
groq.model=llama-3.1-8b-instant
groq.enabled=true

# CORS
cors.allowed-origins=http://localhost:3000

# Logging
logging.level.com.expense=INFO
